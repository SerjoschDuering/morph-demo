{
  "name": "morph-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "copy-wasm": "cp node_modules/esbuild-wasm/esbuild.wasm public/esbuild.wasm",
    "build-vendors": "node scripts/build-vendors.cjs",
    "dev": "npm run copy-wasm && npm run build-vendors && vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run && vitest run -c vitest.bridge.config.ts",
    "test:watch": "vitest",
    "test:bridge": "vitest run -c vitest.bridge.config.ts",
    "test:rust": "cd src-tauri && cargo test --lib",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.72",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-fs": "^2",
    "@tauri-apps/plugin-notification": "^2",
    "@tauri-apps/plugin-os": "^2",
    "@tauri-apps/plugin-shell": "^2",
    "@types/dompurify": "^3.0.5",
    "@types/three": "^0.183.1",
    "d3-force-3d": "^3.0.6",
    "dompurify": "^3.3.3",
    "esbuild-wasm": "^0.28.0",
    "lucide-react": "^0.577.0",
    "marked": "^18.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-force-graph-3d": "^1.29.1",
    "react-markdown": "^9",
    "rehype-highlight": "^7",
    "remark-gfm": "^4",
    "three": "^0.183.2",
    "ws": "^8.19.0",
    "zustand": "^5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4",
    "autoprefixer": "^10",
    "happy-dom": "^20.8.4",
    "postcss": "^8",
    "tailwindcss": "^4",
    "typescript": "^5.7",
    "vite": "^6",
    "vitest": "^4.1.0"
  }
}
